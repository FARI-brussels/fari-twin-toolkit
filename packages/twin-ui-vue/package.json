{
  "name": "@fari-brussels/twin-ui-vue",
  "version": "0.1.0",
  "description": "FARI Vue 3 component library — primitives and domain widgets on @fari-brussels/twin-ui-tokens + @fari-brussels/twin-ui-icons.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fari-brussels/twin-ui-icons": "workspace:*",
    "@fari-brussels/twin-ui-tokens": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.4",
    "vue": "^3.5.12",
    "vue-tsc": "^2.1.10"
  },
  "publishConfig": {
    "access": "public"
  }
}
