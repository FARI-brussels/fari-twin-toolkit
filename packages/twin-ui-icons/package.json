{
  "name": "@fari-brussels/twin-ui-icons",
  "version": "0.1.0",
  "description": "The canonical FARI icon set as tree-shakeable Vue 3 components.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "generate": "node scripts/build-icons.mjs",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "vue": "^3.4"
  },
  "devDependencies": {
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "vue": "^3.5.12"
  },
  "publishConfig": {
    "access": "public"
  }
}
