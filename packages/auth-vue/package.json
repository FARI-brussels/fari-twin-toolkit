{
  "name": "@fari-brussels/auth-vue",
  "version": "0.1.0",
  "description": "Vue 3 Keycloak bindings for FARI apps: a null-safe useAuth composable + redirect-URI helpers.",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@josempgon/vue-keycloak": "^3.3",
    "vue": "^3.4"
  },
  "devDependencies": {
    "@josempgon/vue-keycloak": "^3.3.2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "vue": "^3.5.12"
  },
  "publishConfig": {
    "access": "public"
  }
}
