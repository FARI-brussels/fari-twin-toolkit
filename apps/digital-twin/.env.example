# Copy to `.env` and fill in. `.env` is git-ignored — secrets stay out of the repo.

# Backend API (asset / tileset / map-layer CRUD). Public base URL.
VITE_BACKEND_URL="https://api.mobilitytwin.brussels"

# Keycloak auth. Uncomment + set the URL to enable login-gated features.
#VITE_KEYCLOAK_URL="https://keycloak.digitaltwin.brussels/"
VITE_KEYCLOAK_REALM="master"
VITE_KEYCLOAK_CLIENT_ID="front"
VITE_KEYCLOAK_REDIRECT_PATH="/callback"

# Mobility Twin realtime API token (required for the Realtime library).
# Put your real token here in `.env` — do NOT commit it.
VITE_TWIN_API_TOKEN="<your-mobility-twin-api-token>"

# Optional: Cesium Ion token (for Ion-hosted terrain / assets).
#VITE_CESIUM_ION_TOKEN="<your-cesium-ion-token>"
